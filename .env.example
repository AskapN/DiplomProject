# ── Django ────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-secret-key
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# ── База данных ───────────────────────────────────────────────────────────────
# При DEBUG=True без DB_HOST используется SQLite — DB_* можно не задавать
DB_ENGINE=django.db.backends.postgresql
DB_NAME=orders
DB_USER=orders
DB_PASSWORD=orders_secret
DB_HOST=localhost
DB_PORT=5432

# ── Redis / Celery ────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/1

# ── Email (SMTP, при DEBUG=False) ─────────────────────────────────────────────
DEFAULT_FROM_EMAIL=noreply@example.com
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# ── Sentry / GlitchTip (опционально) ─────────────────────────────────────────
SENTRY_DSN=

# ── Social Auth (опционально) ─────────────────────────────────────────────────
SOCIAL_AUTH_GOOGLE_OAUTH2_KEY=
SOCIAL_AUTH_GOOGLE_OAUTH2_SECRET=
